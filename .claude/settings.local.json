      "Bash(cat:*)",
      "Bash(done)",
      "Bash(export NVM_DIR=\"$HOME/.nvm\")",
      "Bash(. \"$NVM_DIR/nvm.sh\")",
      "Bash(npm install -g @anthropic-ai/claude-code)"
    ]
  }
}
